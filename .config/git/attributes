# Force LF for all text files
* text=auto eol=lf

# Explicit text files
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.conf text eol=lf
*.vim text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.tar.gz binary
*.tar.xz binary
*.zip binary
